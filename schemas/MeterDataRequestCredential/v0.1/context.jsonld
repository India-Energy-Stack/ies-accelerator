{
    "@context": {
        "@version": 1.1,
        "schema": "https://schema.org/",
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "deg": "https://schema.beckn.io/deg/EnergyCredential/v2.0/",
        "ies": "https://raw.githubusercontent.com/India-Energy-Stack/ies-accelerator/main/schemas/",

        "MeterDataRequestCredential": "ies:MeterDataRequestCredential",
        "credentialSubject": "deg:credentialSubject",

        "meterDataRequest": {
            "@id": "ies:meterDataRequest",
            "@type": "@id",
            "@context": {
                "@version": 1.1,
                "@protected": true,
                "resources": {
                    "@id": "ies:resources",
                    "@type": "@id",
                    "@container": "@set"
                },
                "scope": { "@id": "ies:scope", "@type": "xsd:string" },
                "from": { "@id": "ies:from", "@type": "xsd:dateTime" },
                "duration": { "@id": "ies:duration", "@type": "xsd:string" },
                "maxRecordsShared": { "@id": "ies:maxRecordsShared", "@type": "xsd:integer" },
                "includeDetails": {
                    "@id": "ies:includeDetails",
                    "@container": "@set",
                    "@context": {
                        "profileType": { "@id": "ies:profileType", "@type": "xsd:string" },
                        "values": { "@id": "ies:values", "@container": "@set" },
                        "requestedMode": { "@id": "ies:requestedMode", "@type": "xsd:string" }
                    }
                }
            }
        }
    }
}
