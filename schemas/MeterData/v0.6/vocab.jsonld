{
    "@context": {
        "@version": 1.1,
        "ies": "https://raw.githubusercontent.com/India-Energy-Stack/ies-accelerator/main/schemas/ies/",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "schema": "https://schema.org/"
    },
    "@graph": [
        {
            "@id": "ies:MeterData",
            "@type": "rdfs:Class",
            "rdfs:label": "Meter Data",
            "rdfs:comment": "Structural JSON Schema for the six compact profile shapes (CUSTOMER, INTERVAL, DAILY, BILLING, INSTANTANEOUS, EVENT). Discriminated by `profileType`. Sibling to ae-ies-mdm-3rdparty-v0.schema.json (which validates the credential-wrapped form). Both forms share semantics via the JSON-LD context but live in separate schemas because their structural shapes differ (compact omits the W3C VC envelope)."
        },
        {
            "@id": "ies:EnergyData",
            "@type": "rdfs:Class",
            "rdfs:label": "Energy Data",
            "rdfs:comment": "A single compact data-only profile record. Must be one of the eight standard types."
        },
        {
            "@id": "ies:CustomerProfile",
            "@type": "rdfs:Class",
            "rdfs:label": "Customer Profile",
            "rdfs:comment": "Slow-changing customer + service-point + meter-list summary."
        },
        {
            "@id": "ies:BaseTelemetryProfile",
            "@type": "rdfs:Class",
            "rdfs:label": "Base Telemetry Profile",
            "rdfs:comment": ""
        },
        {
            "@id": "ies:IntervalProfile",
            "@type": "rdfs:Class",
            "rdfs:label": "Interval Profile",
            "rdfs:comment": "Block Load Survey — PT15M / PT30M cadence intervalBlocks for one meter."
        },
        {
            "@id": "ies:DailyProfile",
            "@type": "rdfs:Class",
            "rdfs:label": "Daily Profile",
            "rdfs:comment": "Daily Load Profile — P1D intervalBlocks. Same per-meter shape as IntervalProfile."
        },
        {
            "@id": "ies:MonthlyProfile",
            "@type": "rdfs:Class",
            "rdfs:label": "Monthly Profile",
            "rdfs:comment": "Monthly profile readings from the meter at billing reset time (billing history)."
        },
        {
            "@id": "ies:BillDetails",
            "@type": "rdfs:Class",
            "rdfs:label": "Bill Details",
            "rdfs:comment": "Utility billing computed details, such as billing amount, bill number, due dates, and prepaid balance."
        },
        {
            "@id": "ies:InstantaneousProfile",
            "@type": "rdfs:Class",
            "rdfs:label": "Instantaneous Profile",
            "rdfs:comment": "Snapshot of a meter's electrical quantities at one captured moment."
        },
        {
            "@id": "ies:AlarmProfile",
            "@type": "rdfs:Class",
            "rdfs:label": "Alarm Profile",
            "rdfs:comment": "Real-time active indicators/alerts representing immediate state conditions from the meter."
        },
        {
            "@id": "ies:EventProfile",
            "@type": "rdfs:Class",
            "rdfs:label": "Event Profile",
            "rdfs:comment": "IS 15959 event log for one meter over a coverage period."
        },
        {
            "@id": "ies:Identifier",
            "@type": "rdfs:Class",
            "rdfs:label": "Identifier",
            "rdfs:comment": "Canonical {scheme, value} reference. Used for customer/meter/SDP/OBIS references."
        },
        {
            "@id": "ies:TimePeriod",
            "@type": "rdfs:Class",
            "rdfs:label": "Time Period",
            "rdfs:comment": "Period defined by a start time and a duration."
        },
        {
            "@id": "ies:IntervalBlock",
            "@type": "rdfs:Class",
            "rdfs:label": "Interval Block",
            "rdfs:comment": "OpenADR-inspired compact block: descriptors once + positional values per row + sparse quality overrides."
        },
        {
            "@id": "ies:PayloadDescriptor",
            "@type": "rdfs:Class",
            "rdfs:label": "Payload Descriptor",
            "rdfs:comment": "One quantity declared once per block; rows' values[] align positionally with descriptors[]."
        },
        {
            "@id": "ies:IntervalRow",
            "@type": "rdfs:Class",
            "rdfs:label": "Interval Row",
            "rdfs:comment": "One time-series row. values[k] is the value for payloadDescriptors[k]."
        },
        {
            "@id": "ies:Override",
            "@type": "rdfs:Class",
            "rdfs:label": "Override",
            "rdfs:comment": "Sparse — inject timestamps, zones, or validation states into specific interval cells."
        },
        {
            "@id": "ies:Reading",
            "@type": "rdfs:Class",
            "rdfs:label": "Reading",
            "rdfs:comment": "Detailed, self-contained inline reading with full metadata support."
        },
        {
            "@id": "ies:TouBucket",
            "@type": "rdfs:Class",
            "rdfs:label": "Tou Bucket",
            "rdfs:comment": "Time of Use bucket separating readings by zone."
        },
        {
