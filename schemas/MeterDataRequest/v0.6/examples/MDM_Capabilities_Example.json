{
  "@context": "https://raw.githubusercontent.com/India-Energy-Stack/ies-accelerator/main/schemas/MeterDataRequest/v0.6/context.jsonld",
  "@type": "MeterDataCapabilities",
  "profiles": [
    {
      "profileType": "IntervalProfile",
      "readings": [
        { "value": "kWh imp block", "mode": "USAGE", "multiplier": 1.0, "accuracy": 0.5 },
        { "value": "kWh exp block", "mode": "USAGE", "multiplier": 1.0, "accuracy": 0.5 }
      ]
    },
    {
      "profileType": "DailyProfile",
      "readings": [
        { "value": "kWh imp", "mode": "READING" },
        { "value": "kWh exp", "mode": "READING" }
      ]
    },
    {
      "profileType": "InstantaneousProfile",
      "readings": [
        { "value": "V_R", "mode": "READING" },
        { "value": "V_Y", "mode": "READING" },
        { "value": "V_B", "mode": "READING" },
        { "value": "I_R", "mode": "READING" },
        { "value": "I_Y", "mode": "READING" },
        { "value": "I_B", "mode": "READING" }
      ]
    },
    { "profileType": "AlarmProfile" },
    { "profileType": "EventProfile" }
  ],
  "supportedScopes": [ "ResourceOnly", "ResourceAndChildren", "ChildrenOnly" ],
  "maxHistoryDuration": "P3Y"
}
